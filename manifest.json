{
  "manifest_version": 3,
  "name": "ChatGPT 对话快捷删除",
  "description": "在 ChatGPT 左侧对话记录上显示垃圾桶按钮，点击后直接删除该对话。",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ChatGPT 对话快捷删除",
    "default_popup": "popup.html"
  }
}
